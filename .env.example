# ═══════════════════════════════════════════════════════════════════════════════
# Julia - Medicare Allowance Card Eligibility Agent - Environment Configuration
# ═══════════════════════════════════════════════════════════════════════════════
# Copy this file to .env and fill in your values

# ─────────────────────────────────────────────────────────────────────────────
# SignalWire Credentials (required)
# Get these from your SignalWire dashboard: https://signalwire.com
# ─────────────────────────────────────────────────────────────────────────────
SIGNALWIRE_SPACE_NAME=your-space
SIGNALWIRE_PROJECT_ID=your-project-id
SIGNALWIRE_TOKEN=your-api-token

# ─────────────────────────────────────────────────────────────────────────────
# Live agent transfer destination (required for the transfer step)
# Phone number (+15551234567) or SIP address the caller is connected to
# after eligibility data is collected.
# ─────────────────────────────────────────────────────────────────────────────
TRANSFER_DESTINATION=+15551234567
# Optional caller ID override for the transfer leg
# TRANSFER_CALLER_ID=+15559876543

# ─────────────────────────────────────────────────────────────────────────────
# Public URL (auto-detected in production)
# On Dokku/Heroku, APP_URL is set automatically - no need to configure!
# Only set SWML_PROXY_URL_BASE for local development with ngrok/tunnels.
# ─────────────────────────────────────────────────────────────────────────────
# SWML_PROXY_URL_BASE=https://your-ngrok-url.ngrok.io

# ─────────────────────────────────────────────────────────────────────────────
# Basic Auth for SWML endpoints (recommended)
# Set these explicitly: without them the SDK generates random per-process
# credentials, and the URL registered with SignalWire won't authenticate.
# ─────────────────────────────────────────────────────────────────────────────
# SWML_BASIC_AUTH_USER=signalwire
# SWML_BASIC_AUTH_PASSWORD=your-secure-password

# ─────────────────────────────────────────────────────────────────────────────
# Agent Configuration (optional)
# AGENT_NAME is the Fabric resource name; the dialable address becomes
# /public/{AGENT_NAME}. Use a distinct name (e.g. julia-dev) for local runs.
# ─────────────────────────────────────────────────────────────────────────────
AGENT_NAME=julia
PORT=5000

# ─────────────────────────────────────────────────────────────────────────────
# Post-Prompt Webhook (optional)
# If set, a JSON call summary (name, zip, age, transfer status) is sent
# to this URL after each call.
# ─────────────────────────────────────────────────────────────────────────────
# POST_PROMPT_URL=https://your-webhook-url.com/julia/summary
